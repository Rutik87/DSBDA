import nltk

from nltk.tokenize import word_tokenize
from nltk.corpus import stopwords
from nltk.stem import PorterStemmer
from nltk.stem import WordNetLemmatizer

from sklearn.feature_extraction.text import TfidfVectorizer

nltk.download('punkt')
nltk.download('stopwords')
nltk.download('wordnet')
nltk.download('averaged_perceptron_tagger')

text = "Data Analytics is important for machine learning."

# Tokenization
tokens = word_tokenize(text)

tokens

# POS Tagging
pos = nltk.pos_tag(tokens)

pos

# Stop words removal
stop_words = stopwords.words('english')

filtered = [word for word in tokens if word.lower() not in stop_words]

filtered

# Stemming
ps = PorterStemmer()

stemmed = [ps.stem(word) for word in filtered]

stemmed

# Lemmatization
lm = WordNetLemmatizer()

lemmatized = [lm.lemmatize(word) for word in filtered]

lemmatized

# TF-IDF
documents = [
    "Data Analytics is important",
    "Machine learning uses data"
]

tfidf = TfidfVectorizer()

result = tfidf.fit_transform(documents)

result.toarray()
